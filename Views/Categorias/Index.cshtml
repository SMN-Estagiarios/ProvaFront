@{
    ViewData["Title"] = "Categorias";
}

<div class="uk-container">
    <h1 class="uk-heading-divider">Categorias</h1>

    <div class="uk-grid-small" uk-grid>
        <div class="uk-width-1-3@m">
            <div class="uk-card uk-card-default uk-card-body">
                <h3 class="uk-card-title">Cadastro Rápido</h3>
                <form id="form-categoria">
                    <div class="uk-margin">
                        <input class="uk-input" type="text" id="nome-categoria" placeholder="Nome da Categoria" required>
                    </div>
                    <button type="submit" class="uk-button uk-button-primary uk-width-1-1">Salvar</button>
                </form>
            </div>
        </div>
        <div class="uk-width-2-3@m">
            <div class="uk-card uk-card-default uk-card-body">
                <h3 class="uk-card-title">Listagem</h3>
                <table class="uk-table uk-table-divider uk-table-hover">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th class="uk-table-shrink">Ações</th>
                        </tr>
                    </thead>
                    <tbody id="lista-categorias">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/dist/categorias.entry.js" asp-append-version="true"></script>
}

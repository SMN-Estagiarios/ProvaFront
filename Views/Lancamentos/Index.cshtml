@using ProvaFront.Controllers
@using ProvaFront.Extensions

@{
    ViewData["Title"] = "Lançamentos";
}

<div class="uk-container uk-margin-top uk-margin-bottom">
    <div class="uk-flex uk-flex-between uk-flex-middle uk-margin-bottom">
        <h1 class="uk-heading-line uk-margin-remove"><span>Lançamentos</span></h1>
        <button type="button" class="uk-button uk-button-primary" id="btnNovoLancamento" onclick="ProvaFront.lancamentos.abrirModalCadastro()">
            Novo lançamento
        </button>
    </div>

    <div class="uk-card uk-card-default uk-card-body uk-margin-bottom">
        <h3 class="uk-card-title">Filtros</h3>

        <div class="uk-grid-small" uk-grid>
            <div class="uk-width-1-3@m">
                <label class="uk-form-label" for="filtroDescricao">Descrição</label>
                <div class="uk-form-controls">
                    <input class="uk-input" id="filtroDescricao" name="termoBusca"type="text" placeholder="Digite a descrição" />
                </div>
            </div>

            <div class="uk-width-1-4@m">
                <label class="uk-form-label" for="filtroTipo">Tipo</label>
                <div class="uk-form-controls">
                    <select class="uk-select" id="filtroTipo">
                        <option value="">Todos</option>
                        <option value="1">Entrada</option>
                        <option value="2">Saída</option>
                    </select>
                </div>
            </div>

            <div class="uk-width-1-4@m">
                <label class="uk-form-label" for="filtroCategoria">Categoria</label>
                <div class="uk-form-controls">
                    <select class="uk-select" id="filtroCategoria">
                        <option value="">Todas</option>
                    </select>
                </div>
            </div>

            <div class="uk-width-1-4@m">
                <label class="uk-form-label" for="filtroConta">Conta</label>
                <div class="uk-form-controls">
                    <select class="uk-select" id="filtroConta">
                        <option value="">Todas</option>
                    </select>
                </div>
            </div>

            <div class="uk-width-1-6@m">
                <label class="uk-form-label" for="ano">Ano</label>
                <div class="uk-form-controls">
                    <input class="uk-input" id="ano" type="int" />
                </div>
            </div>

            <div class="uk-width-1-6@m">
                <label class="uk-form-label" for="mes">Mês</label>
                <div class="uk-form-controls">
                    <input class="uk-input" id="mes" type="int" />
                </div>
            </div>
            <div class="uk-width-1-4@m">
                <label class="uk-form-label" for="pago">Pago</label>
                <div class="uk-form-controls">
                    <select name="pago" id="pago" class="uk-select">
                        <option value="">Todos</option>
                        <option value="true">Sim</option>
                        <option value="false">Não</option>
                    </select>
                </div>
            </div>

            <div class="uk-width-1-1">
                <div class="uk-flex uk-flex-right uk-gap-small">
                    <button type="button" class="uk-button uk-button-default uk-margin-small-right" id="btnLimparFiltros" onclick="ProvaFront.lancamentos.limparBuscar()">
                        Limpar
                    </button>
                    <button type="button" class="uk-button uk-button-primary" id="btnFiltrar" onclick="ProvaFront.lancamentos.filtrarLancamentos()">
                        Buscar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="uk-card uk-card-default uk-card-body">
        <div class="uk-flex uk-flex-between uk-flex-middle uk-margin-small-bottom">
            <h3 class="uk-card-title uk-margin-remove">Lista de lançamentos</h3>
        </div>

        <ul class="uk-card uk-card-default uk-list uk-list-striped list-hover uk-margin-remove">
            <li class="uk-text-bold uk-width-1-1 uk-padding-small uk-grid-collapse uk-visible@m linha-borda-grid" uk-grid>
                <div class="uk-width-expand uk-text-center@m">
                    <span class="uk-text-bold uk-text-emphasis uk-text-small">Descrição</span>
                </div>
                <div class="uk-width-expand uk-text-center@m">
                    <span class="uk-text-bold uk-text-emphasis uk-text-small">Valor</span>
                </div>
                <div class="uk-width-expand uk-text-center@m">
                    <span class="uk-text-bold uk-text-emphasis uk-text-small">Categoria</span>
                </div>
                <div class="uk-width-expand uk-text-center@m">
                    <span class="uk-text-bold uk-text-emphasis uk-text-small">Conta</span>
                </div>
                <div class="uk-width-expand uk-text-center@m">
                    <span class="uk-text-bold uk-text-emphasis uk-text-small">Tipo</span>
                </div>
                <div class="uk-width-expand uk-text-center@m">
                    <span class="uk-text-bold uk-text-emphasis uk-text-small">Data</span>
                </div>
                <div class="uk-width-expand uk-text-center@m">
                    <span class="uk-text-bold uk-text-emphasis uk-text-small">Ações</span>
                </div>
            </li>
        </ul>

        <ul class="uk-list uk-list-striped list-hover uk-margin-remove" id="listaLancamentos">
            <li>
                <div class="uk-width-expand uk-padding-small">
                    <p class="uk-margin-remove uk-text-secondary uk-text-small uk-text-center">
                        Carregando lançamentos...
                    </p>
                </div>
            </li>
        </ul>
    </div>
</div>

<partial name="_ModalLancamentos" />


@section Scripts {
    <script src="~/dist/lancamentos.entry.js" asp-append-version="true"></script>
    <script>
        ProvaFront.lancamentos.init({
            urls: {
                listar: '@Url.Action(nameof(LancamentosController.Listar).ActionName(),
                    nameof(LancamentosController).ControllerName())',
                buscar: '@Url.Action(nameof(LancamentosController.Buscar).ActionName(),
                    nameof(LancamentosController).ControllerName())',
                cadastrar: '@Url.Action(nameof(LancamentosController.Cadastrar).ActionName(),
                    nameof(LancamentosController).ControllerName())',
                editar: '@Url.Action(nameof(LancamentosController.Editar).ActionName(),
                    nameof(LancamentosController).ControllerName())',
                excluir: '@Url.Action(nameof(LancamentosController.Excluir).ActionName(),
                    nameof(LancamentosController).ControllerName())',
                categorias: '@Url.Action(nameof(CategoriasController.Listar).ActionName(),
                    nameof(CategoriasController).ControllerName())',
                contas: '@Url.Action(nameof(ContasController.Listar).ActionName(),
                    nameof(ContasController).ControllerName())',
                abrirModalLancamento: '@Url.Action(nameof(LancamentosController.AbrirModalLancamento).ActionName(),
                    nameof(LancamentosController).ControllerName())',
            }
        });
    </script>
}
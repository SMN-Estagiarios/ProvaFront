<div id="modalLancamento" uk-modal>
    <div class="uk-modal-dialog uk-modal-body uk-border-rounded uk-margin-auto-vertical uk-width-4-5@s uk-width-3-4@m uk-width-1-2@l">
        
        <div class="uk-flex uk-flex-between uk-flex-middle ">
            <button class="uk-modal-close-default" type="button" uk-close></button>
            <h2 class="uk-modal-title" id="tituloModalLancamento"></h2>
        </div>

        <form id="formLancamento" onsubmit="event.preventDefault(); ProvaFront.lancamentos.salvar(this)">
            <input type="hidden" id="lancamentoId" />

            <div class="uk-margin">
                <label class="uk-form-label" for="descricao">Descrição</label>
                <div class="uk-form-controls">
                    <input class="uk-input" id="descricao" type="text" required name="descricao"/>
                </div>
            </div>

            <div class="uk-grid-small" uk-grid>
                <div class="uk-width-1-2@m">
                    <label class="uk-form-label" for="tipoLancamento">Tipo</label>
                    <div class="uk-form-controls">
                        <select class="uk-select" id="tipoLancamento" required name="tipoLancamento">
                            <option value="1">Entrada</option>
                            <option value="2">Saída</option>
                        </select>
                    </div>
                </div>

                <div class="uk-width-1-2@m">
                    <label class="uk-form-label" for="valor">Valor</label>
                    <div class="uk-form-controls">
                        <input class="uk-input" id="valor" type="number" step="0.01" required name="valor"/>
                    </div>
                </div>

                <div class="uk-width-1-2@m">
                    <label class="uk-form-label" for="dataCompetencia">Data</label>
                    <div class="uk-form-controls">
                        <input class="uk-input" id="dataCompetencia" type="date" required name="dataCompetencia"/>
                    </div>
                </div>

                <div class="uk-width-1-2@m">
                    <label class="uk-form-label" for="categoriaId">Categoria</label>
                    <div class="uk-form-controls">
                        <select class="uk-select" id="categoriaId" required name="categoriaId">
                            <option value="">Selecione</option>
                        </select>
                    </div>
                </div>

                <div class="uk-width-1-2">
                    <label class="uk-form-label" for="contaId">Conta</label>
                    <div class="uk-form-controls">
                        <select class="uk-select" id="contaId" required name="contaId">
                            <option value="">Selecione</option>
                        </select>
                    </div>
                </div>
                <div class="uk-width-1-2 uk-flex uk-flex-column ">
                    <label class="uk-form-label" for="pago">Pago</label>
                    <div class="uk-form-controls uk-flex uk-flex-middle uk-gap-small">
                        <input class="uk-checkbox uk-margin-small-top" id="pago" type="checkbox" name="pago"/>
                    </div>
                </div>
                <div class="uk-width-1-1">
                    <label class="uk-form-label" for="observacao">Observação</label>
                    <div class="uk-form-controls">
                        <textarea class="uk-textarea" id="observacao" name="observacao"></textarea>
                    </div>
                </div>
            </div>

            <div class="uk-flex uk-flex-right uk-gap-small uk-margin-top">
                <button type="button" class="uk-button uk-button-default uk-modal-close uk-margin-small-right">
                    Cancelar
                </button>
                <button type="submit" class="uk-button uk-button-primary" id="btnSalvarLancamento">
                    Salvar
                </button>
            </div>
        </form>
    </div>
</div>
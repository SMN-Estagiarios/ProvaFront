<div id="modal-lancamento" uk-modal>
    <div class="uk-modal-dialog uk-modal-body">
        <h2 class="uk-modal-title">Novo Lançamento</h2>

        <form id="form-lancamento">
            <div class="uk-margin">
                <label class="uk-form-label">Tipo</label>
                <select class="uk-select" id="tipo" name="tipo" required>
                    <option value="1">Receita</option>
                    <option value="2">Despesa</option>
                </select>
            </div>

            <div class="uk-margin">
                <label class="uk-form-label">Descrição</label>
                <input class="uk-input" type="text" id="descricao" name="descricao" required>
            </div>

            <div class="uk-margin">
                <label class="uk-form-label">Valor</label>
                <input class="uk-input" type="number" step="0.01" id="valor" name="valor" required>
            </div>

            <div class="uk-margin">
                <label class="uk-form-label">Data</label>
                <input class="uk-input" type="date" id="dataCompetencia" name="dataCompetencia" required>
            </div>

            <div class="uk-margin">
                <label class="uk-form-label">Categoria</label>
                <select class="uk-select" id="categoriaId" name="categoriaId" required>
                    <option value="">Selecione...</option>
                </select>
            </div>

            <div class="uk-margin">
                <label class="uk-form-label">Conta</label>
                <select class="uk-select" id="contaId" name="contaId" required>
                    <option value="">Selecione...</option>
                </select>
            </div>

            <div class="uk-margin">
                <label class="uk-form-label">
                    <input class="uk-checkbox" type="checkbox" id="pago" name="pago"> Pago
                </label>
            </div>

            <div class="uk-margin">
                <label class="uk-form-label">Observação</label>
                <textarea class="uk-textarea" id="observacao" name="observacao"></textarea>
            </div>
        </form>

        <p class="uk-text-right">
            <button class="uk-button uk-button-default uk-modal-close" type="button">Cancelar</button>
            <button class="uk-button uk-button-primary" type="button" id="btn-salvar-lancamento">Salvar</button>
        </p>
    </div>
</div>

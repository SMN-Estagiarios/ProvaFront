@using ProvaFront.Controllers
@using ProvaFront.Extensions
@{
    ViewData["Title"] = "Contas";
}

<div class="uk-container">
    <h1 class="uk-heading-divider">Contas / Carteiras</h1>

    <div class="uk-grid-small" uk-grid>
        <div class="uk-width-1-3@m">
            <div class="uk-card uk-card-default uk-card-body">
                <h3 class="uk-card-title">Nova Conta</h3>
                <form id="form-conta">
                    <div class="uk-margin">
                        <input class="uk-input" type="text" id="nome-conta" placeholder="Ex.: Nubank, Itaú..." required>
                    </div>
                    <button type="submit" class="uk-button uk-button-primary uk-width-1-1">Adicionar</button>
                </form>
            </div>
        </div>
        <div class="uk-width-2-3@m">
            <div class="uk-card uk-card-default uk-card-body">
                <h3 class="uk-card-title">Minhas Contas</h3>
                <table class="uk-table uk-table-divider uk-table-hover">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th class="uk-table-shrink">Ações</th>
                        </tr>
                    </thead>
                    <tbody id="lista-contas">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/dist/contas.entry.js" asp-append-version="true"></script>
    <script>
        ProvaFront.contas.init({
            urls: {
                listar: '@Url.Action(nameof(ContasController.Listar).ActionName(), nameof(ContasController).ControllerName())',
                cadastrar: '@Url.Action(nameof(ContasController.Cadastrar).ActionName(), nameof(ContasController).ControllerName())',
            }
        });
    </script>
}
